# .env.example — variables d'environnement pour la stack Docker (Phase 8.1)
#
# Copier en .env à la racine et remplir les secrets avant `docker compose up`.
# Les valeurs ci-dessous sont des défauts sensés pour un environnement dev local.
#
# IMPORTANT : ne jamais committer le fichier .env rempli dans git.

# ── Binding backend ────────────────────────────────────────────────────────
SHUGU_HOST=0.0.0.0
SHUGU_PORT=8701

# ── Environnement ──────────────────────────────────────────────────────────
# dev : désactive le guard ip_hash_salt (non requis en dev local).
# production : active tous les guards de sécurité — obligatoire sur VPS.
SHUGU_ENV=dev

# ── Auth opérateur ─────────────────────────────────────────────────────────
# Génère le secret : openssl rand -hex 32
SHUGU_JWT_SECRET=
OPERATOR_USERNAME=Spoukie
# Génère le hash : python -c "import bcrypt; print(bcrypt.hashpw(b'ton-mot-de-passe', bcrypt.gensalt()).decode())"
OPERATOR_PASSWORD_HASH=

# ── Auth utilisateur self-service ──────────────────────────────────────────
# Secret DISTINCT de SHUGU_JWT_SECRET (cloisonnement des surfaces).
# Génère : python -c "import secrets; print(secrets.token_hex(32))"
USER_JWT_SECRET=
USER_ACCESS_TTL_S=3600
USER_REFRESH_TTL_S=2592000

# ── Stockage (container-to-container) ──────────────────────────────────────
# Ces valeurs sont surchargées par docker-compose.yml — listées ici pour
# référence et pour le déploiement bare-metal.
SHUGU_REDIS_URL=redis://redis:6379/1
SHUGU_POSTGRES_DSN=postgresql+asyncpg://shugu@postgres/shugu

# Mot de passe du superuser postgres (utilisé par init-postgres.sh).
POSTGRES_PASSWORD=shugu_dev_password

# ── Crypto ─────────────────────────────────────────────────────────────────
# Obligatoire en production pour pseudonymiser les IPs visiteurs.
# Génère : python -c "import secrets; print(secrets.token_urlsafe(32))"
IP_HASH_SALT=

# ── LLM MiniMax ────────────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimax-m2.7
MINIMAX_PLAN=max

# ── TTS ────────────────────────────────────────────────────────────────────
MINIMAX_VOICE_ID=French_Female_Speech_New
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_SPEED=1.0
ELEVENLABS_API_KEY=
SHUGU_VOICE_ID=OhWejZm6c7D8CIm5epRM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_PRIMARY=minimax
TTS_STREAMING=true

# ── Hermes bridge ──────────────────────────────────────────────────────────
HERMES_API_KEY=
HERMES_BASE_URL=http://127.0.0.1:8642

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Si vide : les emails sont loggés uniquement (NullSender, pas d'erreur).
RESEND_API_KEY=
EMAIL_FROM=shugu@spoukie.uk
PUBLIC_SITE_URL=https://shugu.spoukie.uk

# ── LiveKit ────────────────────────────────────────────────────────────────
# Requis si le profil "vip" est activé (docker compose --profile vip up).
# Dev local Docker  : port 7880 du service livekit, réseau bridge interne.
# Production / VPS  : utiliser wss:// avec TLS (obligatoire en prod).
# Exemple prod      : wss://livekit.example.com
LIVEKIT_URL=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── VIP bridge ─────────────────────────────────────────────────────────────
# Secret HMAC partagé entre le backend et le Worker vip_agent (process séparé).
# Génère : python -c "import secrets; print(secrets.token_hex(32))"
VIP_INTERNAL_URL=http://backend:8701
VIP_INTERNAL_SECRET=

# ── Event bus ──────────────────────────────────────────────────────────────
# "redis" requis en stack Docker multi-container pour le fanout cross-process.
# "inproc" uniquement pour le lancement bare-metal single-process.
EVENT_BUS_MODE=redis

# ── Mémoire long-terme ─────────────────────────────────────────────────────
# false : évite le chargement du modèle fastembed (~2 GB ONNX) au premier boot.
# Activer en true une fois le modèle prêt sur le host.
MEMORY_ENABLED=false
MEMORY_EMBED_DIM=1024
MEMORY_EMBEDDER_MODEL=intfloat/multilingual-e5-large
# Répertoire cache fastembed (vide = ~/.cache/fastembed dans le container).
MEMORY_EMBEDDER_CACHE_DIR=

# ── Director (Embodied Shugu) ──────────────────────────────────────────────
DIRECTOR_ENABLED=false
DIRECTOR_LLM_PROVIDER=minimax
ANTHROPIC_API_KEY=

# ── STT ────────────────────────────────────────────────────────────────────
STT_MODEL=base
STT_COMPUTE_TYPE=int8
STT_DEVICE=auto
STT_LANGUAGE=fr

# ── Policy matrix (Phase 6) ────────────────────────────────────────────────
# Défaut operator_only : fail-safe opt-in.
SHUGU_STREAM_MODE=operator_only

# ── Cloudflare Tunnel ──────────────────────────────────────────────────────
# Utilisé uniquement par le launcher Windows (Shugu-Start.cmd), pas par Docker.
CLOUDFLARE_TUNNEL_TOKEN=
