{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Phase 8.2 — Streamer IA autonome observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(agent_runner_ticks_total[1m])",
          "legendFormat": "tick rate",
          "refId": "A"
        }
      ],
      "title": "Tick rate (ticks/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(agent_runner_actions_applied_total[1m])",
          "legendFormat": "action {{action_kind}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(agent_runner_tools_dispatched_total[1m])",
          "legendFormat": "tool {{tool_name}}",
          "refId": "B"
        }
      ],
      "title": "Actions applied / Tools dispatched (per/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.01}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "table"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(agent_runner_policy_denials_total[1m])",
          "legendFormat": "deny {{mode}} / {{capability}}",
          "refId": "A"
        }
      ],
      "title": "Policy denials (red flag)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(world_delta_published_total[1m])",
          "legendFormat": "world.delta",
          "refId": "A"
        }
      ],
      "title": "world.delta publish rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps", "custom": {"stacking": {"mode": "normal"}}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "options": {"legend": {"displayMode": "table"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(sense_events_received_total[1m])",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "Sense events received by kind (stacked)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["streamer-ia", "phase-8", "observability"],
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
