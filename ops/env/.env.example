# Copy to /home/openclaw/shugu/ops/env/.env and fill in

# Binding
SHUGU_HOST=127.0.0.1
SHUGU_PORT=8701

# Auth
SHUGU_JWT_SECRET=  # openssl rand -hex 32
OPERATOR_USERNAME=Spoukie
OPERATOR_PASSWORD_HASH=  # python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"

# Upstream LLM (Shugu persona + FilterBrain)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimax-m2.7

# TTS
ELEVENLABS_API_KEY=
SHUGU_VOICE_ID=OhWejZm6c7D8CIm5epRM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# MiniMax voice — default = système FR. Pour cloner la voix de Shugu :
#   1) Enregistrer un sample selon tools/voice_clone/record_sample.md
#   2) python tools/voice_clone/upload_clone.py --sample assets/voice/shugu_sample.wav --name shugu_fr_v1
#   3) Coller le voice_id retourné ici
MINIMAX_VOICE_ID=French_MovieLeadFemale
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_SPEED=1.0

# Hermes bridge (from /home/openclaw/.hermes/.env API_SERVER_KEY)
HERMES_API_KEY=
HERMES_BASE_URL=http://127.0.0.1:8642

# Storage
SHUGU_POSTGRES_DSN=postgresql+asyncpg://openclaw@localhost/shugu
SHUGU_REDIS_URL=redis://localhost:6379/1

# Crypto
IP_HASH_SALT=  # openssl rand -hex 16
