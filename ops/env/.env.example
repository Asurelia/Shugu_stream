# Copy to /home/openclaw/shugu/ops/env/.env and fill in

# Binding
SHUGU_HOST=127.0.0.1
SHUGU_PORT=8701

# Auth
SHUGU_JWT_SECRET=  # openssl rand -hex 32
OPERATOR_USERNAME=Spoukie
OPERATOR_PASSWORD_HASH=  # python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"

# Upstream LLM (Shugu persona + FilterBrain)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimax-m2.7

# TTS
ELEVENLABS_API_KEY=
SHUGU_VOICE_ID=OhWejZm6c7D8CIm5epRM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# MiniMax voice — default = système FR. Pour cloner la voix de Shugu :
#   1) Enregistrer un sample selon tools/voice_clone/record_sample.md
#   2) python tools/voice_clone/upload_clone.py --sample assets/voice/shugu_sample.wav --name shugu_fr_v1
#   3) Coller le voice_id retourné ici
MINIMAX_VOICE_ID=French_Female_Speech_New
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_SPEED=1.0

# Storage
SHUGU_POSTGRES_DSN=postgresql+asyncpg://openclaw@localhost/shugu
SHUGU_REDIS_URL=redis://localhost:6379/1

# Crypto
IP_HASH_SALT=  # openssl rand -hex 16

# Auth utilisateur self-service (v4 Phase 1) — DISTINCT du SHUGU_JWT_SECRET.
# Génère : python -c "import secrets; print(secrets.token_hex(32))"
USER_JWT_SECRET=
USER_ACCESS_TTL_S=3600
USER_REFRESH_TTL_S=2592000

# Email (Resend) — si vide, les mails sont log-only (NullSender).
# Inscris-toi sur https://resend.com, vérifie ton domaine (SPF + DKIM DNS).
RESEND_API_KEY=
EMAIL_FROM=shugu@spoukie.uk
PUBLIC_SITE_URL=https://shugu.spoukie.uk

# Cloudflare Tunnel — connector token (UI Zero Trust → Tunnels → Install connector).
# Utilisé par ops/start-shugu.ps1 pour lancer cloudflared.exe.
# Si vide : le tunnel n'est pas démarré et shugu.spoukie.uk reste injoignable
# depuis Internet (mais 127.0.0.1:3005 local marche toujours).
CLOUDFLARE_TUNNEL_TOKEN=

# LiveKit — v4 Phase 3a. Self-hosted livekit-server.exe sur ce PC.
# Génère les keys via : C:\Users\rafai\livekit\livekit-server.exe generate-keys
LIVEKIT_URL=wss://livekit.spoukie.uk
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Event bus — v4 Phase 1 Brique 1.1. `inproc` (défaut, single-worker) ou
# `redis` (fanout cross-process via pub/sub — requis pour que vip_agent émette
# des events visibles côté backend sur plusieurs instances).
EVENT_BUS_MODE=inproc

# Mémoire long-terme — v4 Phase 1 Brique 1.3. `memory_enabled=false` Phase 1
# (l'embedder et l'extraction arrivent Phase 2). La table pgvector + la
# dimension sont posées par la migration 0005 ; changer memory_embed_dim
# nécessite un plan de re-embed.
MEMORY_ENABLED=false
MEMORY_EMBED_DIM=1024

# VIP bridge — v4 Phase 1 Brique 1.2. Communication entre le Worker
# LiveKit (process séparé) et le backend FastAPI via HTTP localhost signé.
# Génère le secret via : python -c "import secrets; print(secrets.token_hex(32))"
VIP_INTERNAL_URL=http://127.0.0.1:8701
VIP_INTERNAL_SECRET=
