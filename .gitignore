# ── Secrets ─────────────────────────────────────────────────────────────
# Real env file with API keys (JWT secret, MiniMax, ElevenLabs, Hermes…).
# Committing it would leak live credentials. The `.example` is safe.
ops/env/.env
*.env.local

# ── Python backend ──────────────────────────────────────────────────────
backend/venv/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Frontend (Node/Next) ───────────────────────────────────────────────
# frontend/.gitignore already ignores node_modules + .next; listed here too
# as a safety net in case that file is removed.
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.swc/

# ── OS / editors ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Logs / tmp ─────────────────────────────────────────────────────────
*.log
tmp/
