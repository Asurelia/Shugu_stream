# ── Secrets ─────────────────────────────────────────────────────────────
# Real env file with API keys (JWT secret, MiniMax, ElevenLabs, Hermes…).
# Committing it would leak live credentials. The `.example` is safe.
ops/env/.env
*.env.local

# ── Python backend ──────────────────────────────────────────────────────
backend/venv/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Frontend (Node/Next) ───────────────────────────────────────────────
# frontend/.gitignore already ignores node_modules + .next; listed here too
# as a safety net in case that file is removed.
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.swc/

# ── OS / editors ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Logs / tmp ─────────────────────────────────────────────────────────
*.log
tmp/

# ── shugustream CLI state (PIDs + captured logs) ───────────────────────
.shugustream/

# ── Design review artifacts (screenshots, visual QA) — local only ──────
# Généré à la volée par les sessions de review (Chrome DevTools MCP,
# Playwright, etc.). Peut être volumineux (~40 MB+), pas besoin en remote.
.design-review/

# ── Claude Code agent state (scheduled tasks, session locks) — local only
.claude/

# ── Voice samples (TTS cloning source audio) — local / private by default
# Les enregistrements de voix sont personnels, potentiellement identifiables.
# On garde le dossier (README + .gitkeep) mais pas les samples eux-mêmes.
assets/voice/*.wav
assets/voice/*.mp3
assets/voice/*.flac
assets/voice/*.ogg
assets/voice/*.m4a
